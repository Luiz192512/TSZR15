{
  "name": "tszr15-whatsapp-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "format": "prettier --write \"app/api/**/*.js\" \"app/auth/actions.js\" \"app/page.js\" \"app/catalogo/page.js\" \"app/pedido/page.js\" \"app/produto/[slug]/page.js\" \"src/components/catalog/*.js\" \"src/lib/*.js\" \"tests/rate-limit.test.mjs\" \"*.{json,mjs}\"",
    "format:check": "prettier --check \"app/api/**/*.js\" \"app/auth/actions.js\" \"app/page.js\" \"app/catalogo/page.js\" \"app/pedido/page.js\" \"app/produto/[slug]/page.js\" \"src/components/catalog/*.js\" \"src/lib/*.js\" \"tests/rate-limit.test.mjs\" \"*.{json,mjs}\"",
    "lint": "eslint app src tests scripts next.config.mjs",
    "start": "next start",
    "clone:preview": "node scripts/clone-supabase-preview.mjs",
    "sync:catalog": "node scripts/sync-supabase-catalog.mjs",
    "sync:catalog:preview": "node scripts/sync-supabase-catalog.mjs --target preview",
    "optimize:product-images": "node scripts/optimize-product-images.mjs --dry-run",
    "optimize:product-images:apply": "node scripts/optimize-product-images.mjs --apply",
    "test": "node --test",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-catalog.mjs",
    "validate:supabase": "node scripts/validate-supabase-catalog.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.4",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sharp": "^0.35.1",
    "supabase": "^2.100.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
