  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "format": "prettier --write \"app/api/**/*.js\" \"app/auth/actions.js\" \"app/page.js\" \"app/catalogo/page.js\" \"app/pedido/page.js\" \"app/produto/[slug]/page.js\" \"src/components/catalog/*.js\" \"src/lib/*.js\" \"tests/rate-limit.test.mjs\" \"*.{json,mjs}\"",
    "format:check": "prettier --check \"app/api/**/*.js\" \"app/auth/actions.js\" \"app/page.js\" \"app/catalogo/page.js\" \"app/pedido/page.js\" \"app/produto/[slug]/page.js\" \"src/components/catalog/*.js\" \"src/lib/*.js\" \"tests/rate-limit.test.mjs\" \"*.{json,mjs}\"",
